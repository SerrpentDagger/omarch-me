#!/bin/bash

# Exit early if we don't have the tte show
if ! command -v tte &>/dev/null; then
  exit 1
fi

# Exit early if screensave is already running
pgrep -f org.omarchy.screensaver && exit 0

# Allow screensaver to be turned off but also force started
if [[ -f ~/.local/state/omarchy/toggles/screensaver-off ]] && [[ $1 != "force" ]]; then
  exit 1
fi

# Silently quit Walker on overlay
walker -q

niri_output_pattern='^Output.*\(\K[^\)]+'

get_monitors() {
  if omarch-me-is-niri; then
    niri msg outputs | grep -oP "$niri_output_pattern"
  else
    hyprctl monitors -j | jq -r '.[] | .name'
  fi
}

focus_monitor() {
  if omarch-me-is-niri; then
    niri msg action focus-monitor $1
  else
    hyprctl dispatch focusmonitor $1
  fi
}

if omarch-me-is-niri; then
  focused=$(niri msg focused-output | grep -oP "$niri_output_pattern")
else
  focused=$(hyprctl monitors -j | jq -r '.[] | select(.focused == true).name')
fi
terminal=$(xdg-terminal-exec --print-id)

for m in $(get_monitors); do
  focus_monitor $m

  case $terminal in
  *Alacritty*)
    spawned_cmd="alacritty --class=org.omarchy.screensaver \
      --config-file ~/.local/share/omarchy/default/alacritty/screensaver.toml \
      -e omarchy-cmd-screensaver"
    ;;
  *ghostty*)
    spawned_cmd="ghostty --class=org.omarchy.screensaver \
      --config-file=~/.local/share/omarchy/default/ghostty/screensaver \
      --font-size=18 \
      -e omarchy-cmd-screensaver"
    ;;
  *kitty*)
    spawned_cmd="kitty --class=org.omarchy.screensaver \
      --override font_size=18 \
      --override window_padding_width=0 \
      -e omarchy-cmd-screensaver"
    ;;
  *)
    spawned_cmd='exit 1'
    notify-send "✋  Screensaver only runs in Alacritty, Ghostty, or Kitty"
    ;;
  esac
  if omarch-me-is-niri; then
    niri msg action spawn-sh -- "$spawned_cmd"
  else
    hyprctl dispatch exec -- $spawned_cmd
  fi
done

focus_monitor $focused
