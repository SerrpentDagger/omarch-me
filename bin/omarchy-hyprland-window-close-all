#!/bin/bash

# Close all open windows
if omarch-me-is-niri; then
  for w in $(niri msg windows | grep -Po "Window ID \K\d+"); do
    niri msg action close-window --id $w &
  done
else
  hyprctl clients -j | \
    jq -r ".[].address" | \
    xargs -I{} hyprctl dispatch closewindow address:{}
fi

# Move to first workspace
hyprctl dispatch workspace 1 || niri msg action focus-workspace 0
